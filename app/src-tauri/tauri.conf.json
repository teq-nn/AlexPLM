{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PLM-Werkzeug",
  "version": "0.1.0",
  "identifier": "de.teqsas.plmwerkzeug",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PLM-Werkzeug",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "backgroundColor": "#0E0D0C"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/bibliothek/bausteine/*.json",
      "resources/bibliothek/toolstacks/*.json",
      "resources/git/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
